# ============================================
# APP ENVIRONMENT
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# CORS 
# ============================================
CORS_ORIGIN=*
ALLOWED_DOMAIN=*

FRONTEND_URL=http://localhost:3001
BACKEND_URL=http://localhost:3000

# ============================================
# Encryption 
# ============================================
ENCRYPTION_KEY=

# ============================================
# JWT 
# ============================================
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=3600s

# ============================================
# Cookies
# ============================================
COOKIE_SECRET=

# ============================================
# GitHub OAuth
# ============================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback

# ============================================
# Stripe
# ============================================
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
STRIPE_INDIE_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_STARTUP_PRICE_ID=price_xxxxxxxxxxxxx

# ============================================
# Paystack (NGN subscriptions)
# ============================================
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx
PAYSTACK_INDIE_PLAN_ID=PLN_xxxxxxxxxxxxx
PAYSTACK_STARTUP_PLAN_ID=PLN_xxxxxxxxxxxxx

# ============================================
# Polar (USD subscriptions)
# ============================================
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_SERVER=sandbox
POLAR_INDIE_PRODUCT_ID=
POLAR_STARTUP_PRODUCT_ID=


# ============================================
# Slack 
# ============================================
SLACK_WEBHOOK_URL=


# ============================================
# SENDGRID (Shared platform email — free plan)
# ============================================
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=
SENDGRID_WEBHOOK_VERIFICATION_KEY=

# ============================================
# RESEND
# ============================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ============================================
# POSTMARK (Shared platform email — free plan)
# ============================================
POSTMARK_API_KEY=
POSTMARK_FROM_EMAIL=
POSTMARK_MESSAGE_STREAM=outbound

# ============================================
# DATABASE (PostgreSQL via Prisma)
# ============================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# For app running on host machine connecting to Docker containers: use localhost
DATABASE_URL=postgresql://notifykit:localdev123@localhost:5432/notifykit

# Docker PostgreSQL Configuration (used by docker-compose.yml)
POSTGRES_USER=notifykit
POSTGRES_PASSWORD=localdev123
POSTGRES_DB=notifykit
POSTGRES_PORT=5432
POSTGRES_CONTAINER_NAME=notifykit-postgres

# ============================================
# REDIS (Queue & Cache)
# ============================================
# For local development with Docker: use localhost as HOST
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CONTAINER_NAME=notifykit-redis

# ============================================
# ADMIN
# ============================================
# Admin email for notifications and support
ADMIN_EMAIL=